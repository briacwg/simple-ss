# ── ServiceSurfer Simple-SS — Environment Variables ──────────────────────────
#
# Copy this file to .env and fill in the values before running locally.
# All variables marked REQUIRED must be set for the app to function.
# Variables marked OPTIONAL enable specific features when present.
#
# Never commit your .env file — it is already in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# ── Security ──────────────────────────────────────────────────────────────────

# REQUIRED — HMAC-SHA256 secret used to sign business phone tokens (callRef).
# Must be identical to CALL_REF_SECRET in the main servicesurfer.app platform
# so that tokens minted by one app are verifiable by the other.
CALL_REF_SECRET=replace-with-a-long-random-secret

# REQUIRED — Secret used to authorize internal QStash dispatch-timeout jobs.
# Set this to any long random string; include it as a Bearer token in QStash
# message headers when publishing to /api/internal/dispatch-timeout.
DISPATCH_JOB_SECRET=replace-with-another-long-random-secret

# ── Upstash Redis ─────────────────────────────────────────────────────────────

# REQUIRED — Upstash Redis REST endpoint (from your Upstash console).
UPSTASH_REDIS_REST_URL=https://your-database.upstash.io

# REQUIRED — Upstash Redis REST auth token.
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

# ── AI (Cerebras) ─────────────────────────────────────────────────────────────

# REQUIRED — Cerebras API key for smart-match query parsing and AI Workspace.
CEREBRAS_API_KEY=csk-your-cerebras-api-key

# OPTIONAL — Cerebras model ID. Defaults to gpt-oss-120b if not set.
# CEREBRAS_MODEL=gpt-oss-120b

# ── Google APIs ───────────────────────────────────────────────────────────────

# REQUIRED — Google Cloud API key.
# Enable: Places API (New), Geocoding API.
GOOGLE_PLACES_API_KEY=AIza-your-google-api-key

# ── Twilio ────────────────────────────────────────────────────────────────────

# REQUIRED — Twilio Account SID (starts with AC...)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# REQUIRED — Twilio Auth Token (shown in the Twilio console).
# Also used to verify X-Twilio-Signature on inbound SMS/voice webhooks.
TWILIO_AUTH_TOKEN=your-twilio-auth-token

# REQUIRED — E.164 Twilio sender number for outbound SMS (e.g. +14015551234).
TWILIO_FROM_NUMBER=+14015551234

# REQUIRED — The bridge phone number that consumers call to be connected to a pro.
# This is the number your Twilio Voice URL is configured on.
# Exposed publicly in the consumer UI (no secret).
PUBLIC_SERVICE_SURFER_CALL_NUMBER=+14015551234

# ── Upstash QStash ────────────────────────────────────────────────────────────

# OPTIONAL — Required to schedule dispatch timeouts and review follow-ups.
# Without these, the dispatch loop works synchronously but no auto-advance or
# review SMS jobs will be scheduled.
QSTASH_URL=https://qstash.upstash.io
QSTASH_TOKEN=your-qstash-token

# OPTIONAL — QStash signing keys for verifying webhook payloads in review-followup.ts.
# Rotate CURRENT → NEXT when you roll your signing keys in the Upstash console.
QSTASH_CURRENT_SIGNING_KEY=sig_your-current-signing-key
QSTASH_NEXT_SIGNING_KEY=sig_your-next-signing-key

# ── Video microservice ────────────────────────────────────────────────────────

# OPTIONAL — Base URL of the video.servicesurfer.app microservice.
# Defaults to https://video.servicesurfer.app if not set.
# VIDEO_APP_URL=https://video.servicesurfer.app

# ── Supabase ─────────────────────────────────────────────────────────────────

# OPTIONAL — Supabase project URL and service-role key.
# Required for: dispatch training events, lead events analytics, passkey auth,
# business dashboard, and workspace settings persistence.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── WebAuthn / Passkeys ───────────────────────────────────────────────────────

# OPTIONAL — WebAuthn relying party configuration.
# RP_ID must match the effective domain of your deployment (no port, no path).
# ORIGIN (PUBLIC_SITE_URL below) must be an exact match for the browser's origin.
WEBAUTHN_RP_ID=simple.servicesurfer.app
WEBAUTHN_RP_NAME=ServiceSurfer Business

# OPTIONAL — Secret for signing business session tokens after passkey authentication.
# Falls back to DISPATCH_JOB_SECRET if not set; generate a separate key for production.
BUSINESS_JWT_SECRET=replace-with-a-long-random-secret-for-sessions

# ── Stripe (billing) ─────────────────────────────────────────────────────────

# OPTIONAL — Required for plan upgrades and subscription management.
# Create your products and prices in the Stripe dashboard, then set the price IDs below.
STRIPE_SECRET_KEY=sk_live_your-stripe-secret-key

# OPTIONAL — Stripe webhook signing secret.
# In the Stripe dashboard, add a webhook for https://your-domain/api/stripe/webhook
# Subscribe to: checkout.session.completed, customer.subscription.updated,
#               customer.subscription.deleted
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-signing-secret

# OPTIONAL — Stripe Price IDs for each plan tier.
# Create recurring subscription prices in Stripe and paste the price IDs here.
STRIPE_PRICE_STARTER=price_your-starter-price-id
STRIPE_PRICE_PRO=price_your-pro-price-id
STRIPE_PRICE_ELITE=price_your-elite-price-id

# ── Site config ───────────────────────────────────────────────────────────────

# OPTIONAL — Canonical public URL of this deployment.
# Used to build absolute callback URLs in QStash publish calls and review SMS links.
# Must match WEBAUTHN_RP_ID origin exactly for passkey authentication to succeed.
PUBLIC_SITE_URL=https://simple.servicesurfer.app
